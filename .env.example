# ============================================
# Chipmo Security AI - Environment Configuration
# ============================================

# --- App ---
APP_NAME=Chipmo Security AI
APP_VERSION=2.0.0
DEBUG=false
PORT=8000

# --- JWT Security (REQUIRED) ---
SECRET_KEY=your-very-long-random-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/chipmo_security
# Or individual params:
DB_NAME=chipmo_security
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Telegram Notifications ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
# Shared secret passed to Telegram via setWebhook({secret_token: ...}).
# Our /api/v1/telegram/webhook endpoint rejects any POST whose
# `X-Telegram-Bot-Api-Secret-Token` header doesn't match this value,
# which stops an attacker who learns the webhook URL from injecting
# fake updates. 32+ random chars — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=

# --- Resend (transactional email — T2-02, T5-06) ---
# Used for signup OTP, welcome email, and ORANGE/RED alert emails.
# Unset → the in-memory RecordingEmailSender takes over (dev/tests).
RESEND_API_KEY=
EMAIL_FROM=Sentry <no-reply@sentry.mn>

# --- Twilio SMS (OTP + RED-severity alert nudges — T2-03, T5-08) ---
# All three required for SMS to activate. Missing any disables SMS
# output; the escalation dispatcher logs it as a failed_at row.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Firebase Cloud Messaging (mobile push — T5-07) ---
# Legacy server-key auth (Google has deprecated this in favour of
# HTTP v1 OAuth; we ship legacy because it keeps `google-auth` out
# of the image). Migrate when we need multicast batching.
FCM_SERVER_KEY=

# --- Email (Gmail SMTP) ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Public URLs (required for on-prem agent installer) ---
# Base URL where the agent binaries are hosted (CDN or object storage).
# The `/api/v1/installer/download/{token}` endpoint issues 302 redirects
# under this prefix: {INSTALLER_BASE_URL}/{os}/install.sh|SentryAgentSetup.exe|sentry-agent.pkg
INSTALLER_BASE_URL=https://downloads.yourdomain.com
# Public API base URL embedded into the agent config.yaml so agents can
# call POST /api/v1/agents/register and heartbeat endpoints from the edge.
PUBLIC_BASE_URL=https://api.yourdomain.com

# --- Default Cameras (optional, legacy support) ---
WIFI_CAMERA_URL=
AXIS_CAMERA_URL=
MAC_CAMERA_INDEX=0

# --- AI ---
AI_SCORE_ALERT_TRIGGER=80.0
AI_ALERT_COOLDOWN=15
AI_AUTO_LEARN=true

# --- RAG (Phase 1: pgvector-backed false-positive suppression) ---
# Vectors are stored in Postgres via the `vector` extension — no
# separate vector service. Railway's managed Postgres ships with the
# extension preinstalled; the alembic migration installs it inside
# the database on first run.
#
# Default OFF on a fresh deploy. Flip to true *after* the migration
# `20260427_02_add_pgvector_to_rag_corpus.py` has applied.
RAG_ENABLED=false
RAG_MODEL_NAME=intfloat/multilingual-e5-small
RAG_TOP_K=5
RAG_DEVICE=cpu

# --- VLM (Phase 2: Qwen2.5-VL alert verification) ---
# Off by default. Two execution modes:
#
#   1. Remote (production pattern): VLM_REMOTE_URL points at the
#      `vlm_server/` microservice running on your own GPU host.
#      Frames are POST'd over HTTPS with a bearer token.
#      → set VLM_ENABLED=true, VLM_REMOTE_URL, VLM_API_KEY
#
#   2. Local (single-box dev / GPU-attached deploy): leave
#      VLM_REMOTE_URL empty. transformers loads Qwen2.5-VL in-process.
#      Requires CUDA on the same host.
#      → set VLM_ENABLED=true, leave VLM_REMOTE_URL=""
#
# VLM_API_KEY is the shared secret between this app and the VLM
# microservice. Generate with: openssl rand -hex 32. Same value MUST
# be set on both sides — the GPU server refuses to start without it.
VLM_ENABLED=false
VLM_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
VLM_DEVICE=cuda
VLM_DTYPE=bfloat16
VLM_TIMEOUT_SECONDS=30
VLM_MAX_NEW_TOKENS=256
VLM_REMOTE_URL=
VLM_API_KEY=

# --- RTSP Reconnect ---
RTSP_RECONNECT_BASE=1
RTSP_RECONNECT_MAX=60

# --- Camera Health ---
CAMERA_HEALTH_HEARTBEAT_INTERVAL_SECONDS=5
CAMERA_HEALTH_OFFLINE_AFTER_SECONDS=30
CAMERA_HEALTH_NOTIFICATION_AFTER_SECONDS=300

# --- Clip Retention ---
MEDIA_RETENTION_ENABLED=true
MEDIA_RETENTION_INTERVAL_SECONDS=86400
NORMAL_CLIP_RETENTION_HOURS=48
ALERT_CLIP_RETENTION_DAYS=30

# --- Sentry (optional) ---
SENTRY_DSN=

# --- Tenant isolation (T1-04 RLS) ---
# Layer-2 defense (Postgres RLS) in addition to the Layer-1 app
# `require_*_access` guards. When false (default), the SQLAlchemy event
# hook sets `app.bypass_tenant='on'` at session start so the RLS
# policies installed by migration 20260422_04 never fire — useful
# during initial rollout. When true, policies enforce per-row
# isolation via `app.current_tenant_id`. Flip to true ONLY after
# confirming every active JWT carries a `tenant_id` claim and the
# migration has been applied.
# Prod: TENANCY_RLS_ENFORCED=true
TENANCY_RLS_ENFORCED=false
