# ============================================
# Chipmo Security AI - Environment Configuration
# ============================================

# --- App ---
APP_NAME=Chipmo Security AI
APP_VERSION=2.0.0
DEBUG=false
PORT=8000

# --- JWT Security (REQUIRED) ---
SECRET_KEY=your-very-long-random-secret-key-here-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- PostgreSQL Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/chipmo_security
# Or individual params:
DB_NAME=chipmo_security
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# --- Telegram Notifications ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Email (Gmail SMTP) ---
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# --- CORS ---
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# --- Default Cameras (optional, legacy support) ---
WIFI_CAMERA_URL=
AXIS_CAMERA_URL=
MAC_CAMERA_INDEX=0

# --- AI ---
AI_SCORE_ALERT_TRIGGER=80.0
AI_ALERT_COOLDOWN=15
AI_AUTO_LEARN=true

# --- Sentry (optional) ---
SENTRY_DSN=
