# Telegram мэдэгдлийн тохиргоо
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# JWT Аюулгүй байдал (ЗААВАЛ тохируулна!)
SECRET_KEY=your-very-long-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# PostgreSQL өгөгдлийн сан
DATABASE_URL=
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=127.0.0.1
DB_PORT=5432

# Email тохиргоо (Gmail SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=your_email@gmail.com

# CORS зөвшөөрөгдсөн домэйнүүд (таслалаар тусгаарлана)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Камерын тохиргоо
WIFI_CAMERA_URL=http://192.168.0.207:4747/video
AXIS_CAMERA_URL=http://185.194.123.84:8001/axis-cgi/mjpg/video.cgi
MAC_CAMERA_INDEX=0
