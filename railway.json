{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python3 shoplift_detector/main.py",
    "restartPolicyType": "ON_FAILURE"
  },
  "nixpacks": {
    "phases": {
      "setup": {
        "nixPkgs": [
          "python3",
          "gcc",
          "libxcb",
          "glib",
          "libGL"
        ],
        "aptPkgs": [
          "libgl1-mesa-glx",
          "libglib2.0-0"
        ]
      },
      "install": {
        "cmds": [
          "pip install --upgrade pip",
          "pip install -r requirements.txt"
        ]
      }
    }
  }
}