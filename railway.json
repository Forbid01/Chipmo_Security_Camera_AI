{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "nixpacks": {
    "phases": {
      "setup": {
        "nixPkgs": ["nodejs_18", "python311", "gcc", "ffmpeg"],
        "aptPkgs": ["libgl1", "libglib2.0-0", "libstdc++6"]
      },
      "install": {
        "cmds": [
          "npm install",
          "python3 -m venv /app/.venv",
          "/app/.venv/bin/pip install --upgrade pip",
          "/app/.venv/bin/pip install -r requirements.txt"
        ]
      }
    },
    "start": {
      "cmd": "export LD_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH && /app/.venv/bin/python3 shoplift_detector/main.py"
    }
  }
}
