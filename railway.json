{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": ". .venv/bin/activate && python3 shoplift_detector/main.py",
    "restartPolicyType": "ON_FAILURE"
  },
  "nixpacks": {
    "phases": {
      "setup": {
        "nixPkgs": [
          "python311",
          "gcc",
          "libxcb",
          "libX11",
          "glib",
          "ffmpeg"
        ],
        "aptPkgs": [
          "libgl1-mesa-glx",
          "libglib2.0-0"
        ]
      },
      "install": {
        "cmds": [
          "python3 -m venv .venv",
          ". .venv/bin/activate && pip install --upgrade pip && pip install -r requirements.txt"
        ]
      }
    }
  }
}